@page
@model LisReportServer.Pages.AccessDeniedModel
@{
    ViewData["Title"] = "访问被拒绝";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm">
                <div class="card-body text-center py-5">
                    <i class="bi bi-shield-exclamation" style="font-size: 4rem; color: #dc3545;"></i>
                    <h1 class="mt-3 text-danger">访问被拒绝</h1>
                    <p class="lead mt-3">您没有权限访问此页面。</p>
                    
                    @if (!string.IsNullOrEmpty(Model.Message))
                    {
                        <div class="alert alert-warning mt-3">
                            @Model.Message
                        </div>
                    }
                    
                    <div class="mt-4">
                        <p class="text-muted">
                            此页面仅限本地系统管理员访问。如果您需要访问此页面，请联系系统管理员。
                        </p>
                    </div>
                    
                    <div class="mt-4">
                        <a href="/" class="btn btn-primary">
                            <i class="bi bi-house-door"></i> 返回首页
                        </a>
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <a href="/Logout" class="btn btn-secondary ms-2">
                                <i class="bi bi-box-arrow-right"></i> 注销登录
                            </a>
                        }
                        else
                        {
                            <a href="/Login" class="btn btn-secondary ms-2">
                                <i class="bi bi-box-arrow-in-right"></i> 重新登录
                            </a>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
